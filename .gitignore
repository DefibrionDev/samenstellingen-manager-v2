/vendor/
/tmp/*
!/tmp/.gitkeep
# Frontend build-output — gegenereerd door `npm --prefix web run build`.
/public/index.html
/public/assets/
/web/node_modules/
/web/dist/
*.sqlite
*.sqlite-journal
*.csv
*.xlsx
*.xls
*.txt
.~lock.*
.env
.phpunit.result.cache
.phpunit.cache/
.php-cs-fixer.cache
output.txt

# migratie-mapping is wél onderdeel van de tooling
!migration/*.csv

# Python bytecode-cache (migratiescripts)
__pycache__/
*.pyc
