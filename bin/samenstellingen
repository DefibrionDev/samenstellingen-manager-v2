#!/usr/bin/env php
<?php

declare(strict_types=1);

use Defibrion\Samenstellingen\Application\Accessoire\CreateAccessoireHandler;
use Defibrion\Samenstellingen\Application\Afas\BlacklistBomCodeHandler;
use Defibrion\Samenstellingen\Application\Afas\ListBomBlacklistHandler;
use Defibrion\Samenstellingen\Application\Afas\PullAfasSamenstellingenHandler;
use Defibrion\Samenstellingen\Application\Audit\ListMissingVariantsHandler;
use Defibrion\Samenstellingen\Application\Group\AddAccessoireToGroupHandler;
use Defibrion\Samenstellingen\Application\Group\AddBaseItemHandler;
use Defibrion\Samenstellingen\Application\Group\AddBaseToGroupHandler;
use Defibrion\Samenstellingen\Application\Group\CreateGroupHandler;
use Defibrion\Samenstellingen\Application\Group\ShowGroupHandler;
use Defibrion\Samenstellingen\Application\Group\SyncGroupAgainstAfasHandler;
use Defibrion\Samenstellingen\Application\Import\ImportPortalCsvHandler;
use Defibrion\Samenstellingen\Application\Import\ImportSamenstellingenCsvHandler;
use Defibrion\Samenstellingen\Domain\Afas\AfasSamenstellingLookup;
use Defibrion\Samenstellingen\Domain\Afas\VariantMatcher;
use Defibrion\Samenstellingen\Infrastructure\Afas\Http\AfasClientFactory;
use Defibrion\Samenstellingen\Infrastructure\Afas\Http\HttpAfasSamenstellingenFetcher;
use Defibrion\Samenstellingen\Infrastructure\Import\FileCsvSamenstellingenReader;
use Defibrion\Samenstellingen\Infrastructure\Import\FilePortalCsvReader;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteToolDataWiper;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\Migrator;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteAccessoireRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteAfasSamenstellingenRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteBomBlacklistRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupAccessoireRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupBaseItemRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupBaseRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupVariantRepository;
use Defibrion\Samenstellingen\Interface\Cli\AddAccessoireCommand;
use Defibrion\Samenstellingen\Interface\Cli\AddBaseCommand;
use Defibrion\Samenstellingen\Interface\Cli\AddBaseItemCommand;
use Defibrion\Samenstellingen\Interface\Cli\AfasListDuplicatesCommand;
use Defibrion\Samenstellingen\Interface\Cli\AfasPullCommand;
use Defibrion\Samenstellingen\Interface\Cli\BlacklistBomCommand;
use Defibrion\Samenstellingen\Interface\Cli\CreateAccessoireCommand;
use Defibrion\Samenstellingen\Interface\Cli\CreateGroupCommand;
use Defibrion\Samenstellingen\Interface\Cli\ExportMissingVariantsCommand;
use Defibrion\Samenstellingen\Interface\Cli\ImportPortalCsvCommand;
use Defibrion\Samenstellingen\Interface\Cli\ImportSamenstellingenCsvCommand;
use Defibrion\Samenstellingen\Interface\Cli\ListBomBlacklistCommand;
use Defibrion\Samenstellingen\Interface\Cli\ShowGroupCommand;
use Defibrion\Samenstellingen\Interface\Cli\SyncGroupAgainstAfasCommand;
use Symfony\Component\Console\Application;
use Symfony\Component\Dotenv\Dotenv;

require_once __DIR__ . '/../vendor/autoload.php';

$projectRoot = dirname(__DIR__);

if (file_exists($projectRoot . '/.env')) {
    (new Dotenv())->load($projectRoot . '/.env');
}

$dbPath = $_ENV['SAMENSTELLINGEN_DB_PATH'] ?? $projectRoot . '/tmp/samenstellingen.sqlite';
$dbDir = dirname($dbPath);
if (!is_dir($dbDir)) {
    mkdir($dbDir, 0o755, true);
}

$pdo = new PDO('sqlite:' . $dbPath);
$pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
$pdo->exec('PRAGMA foreign_keys = ON');

(new Migrator($pdo, $projectRoot . '/migrations'))->migrate();

$groupRepository = new SqliteGroupRepository($pdo);
$baseRepository = new SqliteGroupBaseRepository($pdo);
$baseItemRepository = new SqliteGroupBaseItemRepository($pdo);
$accessoireRepository = new SqliteAccessoireRepository($pdo);
$linkRepository = new SqliteGroupAccessoireRepository($pdo);
$variantRepository = new SqliteGroupVariantRepository($pdo);
$afasSamenstellingenRepository = new SqliteAfasSamenstellingenRepository($pdo);
$bomBlacklistRepository = new SqliteBomBlacklistRepository($pdo);

$createGroupHandler = new CreateGroupHandler($groupRepository);
$showGroupHandler = new ShowGroupHandler(
    $groupRepository,
    $baseRepository,
    $baseItemRepository,
    $linkRepository,
    $variantRepository,
);
$addBaseHandler = new AddBaseToGroupHandler($baseRepository, $variantRepository);
$addBaseItemHandler = new AddBaseItemHandler($baseItemRepository);
$createAccessoireHandler = new CreateAccessoireHandler($accessoireRepository);
$addAccessoireHandler = new AddAccessoireToGroupHandler($linkRepository, $variantRepository);
$syncHandler = new SyncGroupAgainstAfasHandler(
    $variantRepository,
    $baseItemRepository,
    $afasSamenstellingenRepository,
    new VariantMatcher(),
);
$importCsvHandler = new ImportSamenstellingenCsvHandler(
    new FileCsvSamenstellingenReader(),
    $baseRepository,
    $accessoireRepository,
    $linkRepository,
    $variantRepository,
);
$importPortalCsvHandler = new ImportPortalCsvHandler(
    new FilePortalCsvReader(),
    new SqliteToolDataWiper($pdo),
    $groupRepository,
    $baseRepository,
    $baseItemRepository,
    $variantRepository,
    new AfasSamenstellingLookup($afasSamenstellingenRepository),
    $accessoireRepository,
    $bomBlacklistRepository,
);
$blacklistBomHandler = new BlacklistBomCodeHandler($bomBlacklistRepository);
$listBomBlacklistHandler = new ListBomBlacklistHandler($bomBlacklistRepository);
$listMissingHandler = new ListMissingVariantsHandler(
    $groupRepository,
    $variantRepository,
    $baseItemRepository,
);

$application = new Application('samenstellingen-manager');
$application->addCommand(new CreateGroupCommand($createGroupHandler));
$application->addCommand(new ShowGroupCommand($showGroupHandler));
$application->addCommand(new AddBaseCommand($addBaseHandler));
$application->addCommand(new AddBaseItemCommand($addBaseItemHandler));
$application->addCommand(new CreateAccessoireCommand($createAccessoireHandler));
$application->addCommand(new AddAccessoireCommand($addAccessoireHandler));
$application->addCommand(new ImportSamenstellingenCsvCommand($importCsvHandler));
$application->addCommand(new ImportPortalCsvCommand($importPortalCsvHandler));
$application->addCommand(new AfasListDuplicatesCommand($afasSamenstellingenRepository));
$application->addCommand(new BlacklistBomCommand($blacklistBomHandler));
$application->addCommand(new ListBomBlacklistCommand($listBomBlacklistHandler));
$application->addCommand(new ExportMissingVariantsCommand($listMissingHandler));
$application->addCommand(new SyncGroupAgainstAfasCommand($syncHandler));

// `afas:pull` heeft credentials nodig en bouwt zelf z'n fetcher.
$hasAfasCreds = is_string($_ENV['AFAS_BASE_URL'] ?? null) && ($_ENV['AFAS_BASE_URL'] ?? '') !== ''
    && is_string($_ENV['AFAS_TOKEN'] ?? null) && ($_ENV['AFAS_TOKEN'] ?? '') !== '';
if ($hasAfasCreds) {
    $fetcher = new HttpAfasSamenstellingenFetcher(AfasClientFactory::fromEnv());
    $pullHandler = new PullAfasSamenstellingenHandler($fetcher, $afasSamenstellingenRepository);
    $application->addCommand(new AfasPullCommand($pullHandler));
}

exit($application->run());
