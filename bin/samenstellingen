#!/usr/bin/env php
<?php

declare(strict_types=1);

use Defibrion\Samenstellingen\Application\Accessoire\CreateAccessoireHandler;
use Defibrion\Samenstellingen\Application\Accessoire\DeleteAccessoireHandler;
use Defibrion\Samenstellingen\Application\Accessoire\SetAccessoireDeltaHandler;
use Defibrion\Samenstellingen\Application\Afas\BlacklistBomCodeHandler;
use Defibrion\Samenstellingen\Application\Afas\ListBomBlacklistHandler;
use Defibrion\Samenstellingen\Application\Afas\PullAfasSamenstellingenHandler;
use Defibrion\Samenstellingen\Application\Audit\ListMissingVariantsHandler;
use Defibrion\Samenstellingen\Application\Audit\NameAuditHandler;
use Defibrion\Samenstellingen\Application\Audit\DuplicateBomAuditHandler;
use Defibrion\Samenstellingen\Application\Audit\PriceAuditHandler;
use Defibrion\Samenstellingen\Application\Audit\StickerAuditHandler;
use Defibrion\Samenstellingen\Application\Audit\SuspiciousBaseAuditHandler;
use Defibrion\Samenstellingen\Application\Group\AddAccessoireToGroupHandler;
use Defibrion\Samenstellingen\Application\Group\AddBaseFromAfasHandler;
use Defibrion\Samenstellingen\Application\Group\AddBaseItemHandler;
use Defibrion\Samenstellingen\Application\Group\AddBaseToGroupHandler;
use Defibrion\Samenstellingen\Application\Group\RemoveBaseHandler;
use Defibrion\Samenstellingen\Application\Group\CreateGroupHandler;
use Defibrion\Samenstellingen\Application\Group\ShowGroupHandler;
use Defibrion\Samenstellingen\Application\Group\SyncAllGroupsHandler;
use Defibrion\Samenstellingen\Application\Group\SyncGroupAgainstAfasHandler;
use Defibrion\Samenstellingen\Application\Import\ImportPortalCsvHandler;
use Defibrion\Samenstellingen\Application\Import\ImportSamenstellingenCsvHandler;
use Defibrion\Samenstellingen\Domain\Afas\AfasSamenstellingLookup;
use Defibrion\Samenstellingen\Domain\Afas\VariantMatcher;
use Defibrion\Samenstellingen\Domain\Naming\VariantNamingPolicy;
use Defibrion\Samenstellingen\Infrastructure\Afas\Http\AfasClientFactory;
use Defibrion\Samenstellingen\Infrastructure\Afas\Http\HttpAfasArticlesFetcher;
use Defibrion\Samenstellingen\Infrastructure\Afas\Http\HttpAfasPrijslijstenFetcher;
use Defibrion\Samenstellingen\Infrastructure\Afas\Http\HttpAfasPrijzenFetcher;
use Defibrion\Samenstellingen\Infrastructure\Afas\Http\HttpAfasSamenstellingenFetcher;
use Defibrion\Samenstellingen\Infrastructure\Import\FileCsvSamenstellingenReader;
use Defibrion\Samenstellingen\Infrastructure\Import\FilePortalCsvReader;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\Migrator;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteAccessoireRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteAfasSamenstellingenRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteBomBlacklistRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupAccessoireRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupBaseItemRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupBaseRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupRepository;
use Defibrion\Samenstellingen\Infrastructure\Persistence\Sqlite\SqliteGroupVariantRepository;
use Defibrion\Samenstellingen\Interface\Cli\AddAccessoireCommand;
use Defibrion\Samenstellingen\Interface\Cli\AddBaseCommand;
use Defibrion\Samenstellingen\Interface\Cli\AddBaseFromAfasCommand;
use Defibrion\Samenstellingen\Interface\Cli\AddBaseItemCommand;
use Defibrion\Samenstellingen\Interface\Cli\RemoveBaseCommand;
use Defibrion\Samenstellingen\Interface\Cli\AfasListDuplicatesCommand;
use Defibrion\Samenstellingen\Interface\Cli\AfasPullCommand;
use Defibrion\Samenstellingen\Interface\Cli\BlacklistBomCommand;
use Defibrion\Samenstellingen\Interface\Cli\WhitelistPrijslijstCommand;
use Defibrion\Samenstellingen\Interface\Cli\ListPrijslijstWhitelistCommand;
use Defibrion\Samenstellingen\Interface\Cli\UnwhitelistPrijslijstCommand;
use Defibrion\Samenstellingen\Interface\Cli\AuditNamesCommand;
use Defibrion\Samenstellingen\Interface\Cli\AuditDuplicateBomsCommand;
use Defibrion\Samenstellingen\Application\Fix\FixNamesHandler;
use Defibrion\Samenstellingen\Application\Fix\FixPriceDriftHandler;
use Defibrion\Samenstellingen\Application\Fix\FixPriceMissingHandler;
use Defibrion\Samenstellingen\Infrastructure\Fix\HttpFbCompositionNameWriter;
use Defibrion\Samenstellingen\Infrastructure\Fix\HttpFbSalesPriceWriter;
use Defibrion\Samenstellingen\Infrastructure\Fix\HttpGetPrijzenBeginDateLookup;
use Defibrion\Samenstellingen\Interface\Cli\AuditPricesCommand;
use Defibrion\Samenstellingen\Interface\Cli\AuditStickersCommand;
use Defibrion\Samenstellingen\Interface\Cli\FixNamesCommand;
use Defibrion\Samenstellingen\Interface\Cli\FixPriceDriftCommand;
use Defibrion\Samenstellingen\Interface\Cli\FixPriceMissingCommand;
use Defibrion\Samenstellingen\Interface\Cli\AuditSuspiciousBasesCommand;
use Defibrion\Samenstellingen\Interface\Cli\CreateAccessoireCommand;
use Defibrion\Samenstellingen\Interface\Cli\DeleteAccessoireCommand;
use Defibrion\Samenstellingen\Interface\Cli\SetAccessoireDeltaCommand;
use Defibrion\Samenstellingen\Interface\Cli\SetAccessoireNaamKortCommand;
use Defibrion\Samenstellingen\Interface\Cli\SetBaseVariantLabelCommand;
use Defibrion\Samenstellingen\Interface\Cli\SetGroupModelNaamCommand;
use Defibrion\Samenstellingen\Interface\Cli\CreateGroupCommand;
use Defibrion\Samenstellingen\Interface\Cli\ExportMissingVariantsCommand;
use Defibrion\Samenstellingen\Interface\Cli\ImportPortalCsvCommand;
use Defibrion\Samenstellingen\Interface\Cli\ImportSamenstellingenCsvCommand;
use Defibrion\Samenstellingen\Interface\Cli\ListBomBlacklistCommand;
use Defibrion\Samenstellingen\Interface\Cli\ShowGroupCommand;
use Defibrion\Samenstellingen\Interface\Cli\SyncGroupAgainstAfasCommand;
use Symfony\Component\Console\Application;
use Symfony\Component\Dotenv\Dotenv;

require_once __DIR__ . '/../vendor/autoload.php';

$projectRoot = dirname(__DIR__);

if (file_exists($projectRoot . '/.env')) {
    (new Dotenv())->load($projectRoot . '/.env');
}

$dbPath = $_ENV['SAMENSTELLINGEN_DB_PATH'] ?? $projectRoot . '/tmp/samenstellingen.sqlite';

$container = new \Defibrion\Samenstellingen\Bootstrap\Container($dbPath, $projectRoot . '/migrations');
$pdo = $container->pdo();

$groupRepository = $container->groupRepository();
$baseRepository = $container->baseRepository();
$baseItemRepository = $container->baseItemRepository();
$accessoireRepository = $container->accessoireRepository();
$linkRepository = $container->linkRepository();
$variantRepository = $container->variantRepository();
$afasSamenstellingenRepository = $container->afasSamenstellingenRepository();
$bomBlacklistRepository = $container->bomBlacklistRepository();
$afasArticleRepository = $container->afasArticleRepository();
$afasPrijsRepository = $container->afasPrijsRepository();
$afasPrijslijstRepository = $container->afasPrijslijstRepository();
$prijslijstWhitelistRepository = $container->prijslijstWhitelistRepository();

$createGroupHandler = new CreateGroupHandler($groupRepository);
$showGroupHandler = new ShowGroupHandler(
    $groupRepository,
    $baseRepository,
    $baseItemRepository,
    $linkRepository,
    $variantRepository,
);
$addBaseHandler = new AddBaseToGroupHandler($baseRepository, $variantRepository);
$removeBaseHandler = new RemoveBaseHandler($baseRepository, $variantRepository);
$addBaseFromAfasHandler = new AddBaseFromAfasHandler(
    $groupRepository,
    $baseRepository,
    $baseItemRepository,
    $variantRepository,
    $afasSamenstellingenRepository,
);
$addBaseItemHandler = new AddBaseItemHandler($baseItemRepository);
$createAccessoireHandler = new CreateAccessoireHandler($accessoireRepository);
$setAccessoireDeltaHandler = new SetAccessoireDeltaHandler($accessoireRepository);
$deleteAccessoireHandler = new DeleteAccessoireHandler(
    $accessoireRepository,
    $groupRepository,
    $linkRepository,
    $variantRepository,
);
$addAccessoireHandler = new AddAccessoireToGroupHandler($linkRepository, $variantRepository);
$syncHandler = new SyncGroupAgainstAfasHandler(
    $variantRepository,
    $baseItemRepository,
    $afasSamenstellingenRepository,
    new VariantMatcher(),
);
$syncAllGroupsHandler = new SyncAllGroupsHandler(
    $groupRepository,
    $syncHandler,
    $afasSamenstellingenRepository,
);
$importCsvHandler = new ImportSamenstellingenCsvHandler(
    new FileCsvSamenstellingenReader(),
    $baseRepository,
    $accessoireRepository,
    $linkRepository,
    $variantRepository,
);
$importPortalCsvHandler = new ImportPortalCsvHandler(
    new FilePortalCsvReader(),
    $groupRepository,
    $baseRepository,
    $baseItemRepository,
    $variantRepository,
    new AfasSamenstellingLookup($afasSamenstellingenRepository),
    $accessoireRepository,
    $bomBlacklistRepository,
    $syncAllGroupsHandler,
    $afasArticleRepository,
);
$blacklistBomHandler = new BlacklistBomCodeHandler($bomBlacklistRepository);
$listBomBlacklistHandler = new ListBomBlacklistHandler($bomBlacklistRepository);
$listMissingHandler = new ListMissingVariantsHandler(
    $groupRepository,
    $variantRepository,
    $baseItemRepository,
);
$nameAuditHandler = new NameAuditHandler(
    $groupRepository,
    $baseRepository,
    $variantRepository,
    $accessoireRepository,
    $afasSamenstellingenRepository,
    new VariantNamingPolicy(),
);
$suspiciousBaseAuditHandler = new SuspiciousBaseAuditHandler(
    $afasSamenstellingenRepository,
    $accessoireRepository,
);
$priceAuditHandler = new PriceAuditHandler(
    $groupRepository,
    $baseRepository,
    $linkRepository,
    $afasPrijsRepository,
    $afasPrijslijstRepository,
    $prijslijstWhitelistRepository,
);

$application = new Application('samenstellingen-manager');
$application->addCommand(new CreateGroupCommand($createGroupHandler));
$application->addCommand(new ShowGroupCommand($showGroupHandler));
$application->addCommand(new AddBaseCommand($addBaseHandler));
$application->addCommand(new AddBaseFromAfasCommand($addBaseFromAfasHandler));
$application->addCommand(new RemoveBaseCommand($removeBaseHandler));
$application->addCommand(new AddBaseItemCommand($addBaseItemHandler));
$application->addCommand(new CreateAccessoireCommand($createAccessoireHandler));
$application->addCommand(new DeleteAccessoireCommand($deleteAccessoireHandler));
$application->addCommand(new SetAccessoireDeltaCommand($setAccessoireDeltaHandler));
$application->addCommand(new SetAccessoireNaamKortCommand($accessoireRepository));
$application->addCommand(new SetGroupModelNaamCommand($groupRepository));
$application->addCommand(new SetBaseVariantLabelCommand($baseRepository));
$application->addCommand(new AddAccessoireCommand($addAccessoireHandler));
$application->addCommand(new ImportSamenstellingenCsvCommand($importCsvHandler));
$application->addCommand(new ImportPortalCsvCommand($importPortalCsvHandler));
$application->addCommand(new AfasListDuplicatesCommand($afasSamenstellingenRepository));
$application->addCommand(new BlacklistBomCommand($blacklistBomHandler));
$application->addCommand(new ListBomBlacklistCommand($listBomBlacklistHandler));
$application->addCommand(new ExportMissingVariantsCommand($listMissingHandler));
$application->addCommand(new AuditNamesCommand($nameAuditHandler));
$application->addCommand(new AuditSuspiciousBasesCommand($suspiciousBaseAuditHandler));
$application->addCommand(new AuditPricesCommand($priceAuditHandler));
$application->addCommand(new AuditDuplicateBomsCommand(new DuplicateBomAuditHandler($afasSamenstellingenRepository)));
$application->addCommand(new AuditStickersCommand(new StickerAuditHandler($groupRepository, $baseRepository, $afasSamenstellingenRepository)));
$application->addCommand(new WhitelistPrijslijstCommand($prijslijstWhitelistRepository));
$application->addCommand(new UnwhitelistPrijslijstCommand($prijslijstWhitelistRepository));
$application->addCommand(new ListPrijslijstWhitelistCommand($prijslijstWhitelistRepository, $afasPrijslijstRepository));
$application->addCommand(new SyncGroupAgainstAfasCommand($syncHandler));

// `afas:pull` heeft credentials nodig en bouwt zelf z'n fetcher.
$hasAfasCreds = is_string($_ENV['AFAS_BASE_URL'] ?? null) && ($_ENV['AFAS_BASE_URL'] ?? '') !== ''
    && is_string($_ENV['AFAS_TOKEN'] ?? null) && ($_ENV['AFAS_TOKEN'] ?? '') !== '';
if ($hasAfasCreds) {
    $afasClient = AfasClientFactory::fromEnv();
    $fetcher = new HttpAfasSamenstellingenFetcher($afasClient);
    $articlesFetcher = new HttpAfasArticlesFetcher($afasClient);
    $prijzenFetcher = new HttpAfasPrijzenFetcher($afasClient, $prijslijstWhitelistRepository);
    $prijslijstenFetcher = new HttpAfasPrijslijstenFetcher($afasClient);
    $pullHandler = new PullAfasSamenstellingenHandler(
        $fetcher,
        $afasSamenstellingenRepository,
        $articlesFetcher,
        $afasArticleRepository,
        $syncAllGroupsHandler,
        $prijzenFetcher,
        $afasPrijsRepository,
        $prijslijstenFetcher,
        $afasPrijslijstRepository,
    );
    $application->addCommand(new AfasPullCommand($pullHandler));

    $fbSalesPriceWriter = new HttpFbSalesPriceWriter($afasClient);
    $beginDateLookup = new HttpGetPrijzenBeginDateLookup($afasClient);
    $fixPriceDriftHandler = new FixPriceDriftHandler(
        $priceAuditHandler,
        $beginDateLookup,
        $fbSalesPriceWriter,
    );
    $application->addCommand(new FixPriceDriftCommand($fixPriceDriftHandler));

    $fixPriceMissingHandler = new FixPriceMissingHandler(
        $priceAuditHandler,
        $beginDateLookup,
        $afasArticleRepository,
        $fbSalesPriceWriter,
    );
    $application->addCommand(new FixPriceMissingCommand($fixPriceMissingHandler));

    $nameWriter = new HttpFbCompositionNameWriter($afasClient);
    $fixNamesHandler = new FixNamesHandler($nameAuditHandler, $nameWriter);
    $application->addCommand(new FixNamesCommand($fixNamesHandler));
}

exit($application->run());
