{
    "name": "defibrion/samenstellingen-manager",
    "description": "Beheertool voor AED-samenstellingen in AFAS (taal × accessoire matrix).",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.5",
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "guzzlehttp/guzzle": "^7.10",
        "symfony/console": "^8.0",
        "symfony/dotenv": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Defibrion\\Samenstellingen\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Defibrion\\Samenstellingen\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "fix": "php-cs-fixer fix",
        "check": [
            "@lint",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {}
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
