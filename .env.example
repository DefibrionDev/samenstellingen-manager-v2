# Pad naar het lokale SQLite-bestand met groepsdefinities en AFAS-snapshots.
# Gebruik een absoluut pad of relatief vanaf de project-root.
SAMENSTELLINGEN_DB_PATH=./tmp/samenstellingen.sqlite

# AFAS REST API endpoint en token voor `group:sync-afas`.
# Beide moeten gezet zijn om AFAS-matching te kunnen draaien.
AFAS_BASE_URL=https://12345.rest.afas.online/profitrestservices
AFAS_TOKEN=
